# latticesql — environment variables
#
# None of these are required to use Lattice as a library or to run `lattice gui`.
# They configure the GUI's optional AI assistant (2.0+), which stays inert until
# a credential is present. Keys set here are a fallback; the GUI also stores them
# encrypted in the native `secrets` entity (User Settings → Assistant).

# ── Claude (assistant chat + file ingest) ───────────────────────────────────
# An Anthropic API key enables the assistant immediately.
ANTHROPIC_API_KEY=

# ── Claude subscription OAuth (optional, dormant until all four are set) ─────
# The PKCE "Connect your Claude subscription" flow is config-driven; supply the
# concrete Anthropic OAuth values to surface the Connect button in the GUI.
# Use a fixed GUI port so the redirect URI stays stable (lattice gui --port 4317).
ANTHROPIC_OAUTH_AUTHORIZE_URL=
ANTHROPIC_OAUTH_TOKEN_URL=
ANTHROPIC_OAUTH_CLIENT_ID=
ANTHROPIC_OAUTH_REDIRECT_URI=
ANTHROPIC_OAUTH_SCOPES=
# Optional beta header sent on the OAuth (bearer-token) path.
ANTHROPIC_OAUTH_BETA=

# ── File extraction (optional) ──────────────────────────────────────────────
# Path to the `markitdown` CLI for PDF/Office text extraction. When unset (and
# `markitdown` isn't on PATH), those files are referenced but not text-extracted.
MARKITDOWN_BIN=markitdown

# ── Voice input (optional, pick either) ─────────────────────────────────────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# ── Secret encryption (optional) ────────────────────────────────────────────
# Key used to encrypt the `secrets` entity at rest. Auto-generated at
# ~/.lattice/master.key when unset.
LATTICE_ENCRYPTION_KEY=
