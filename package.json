{
  "name": "latticesql",
  "version": "3.4.5",
  "description": "Persistent structured memory for AI agent systems — pluggable SQLite or Postgres backend, LLM context bridge",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "lattice": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:generic": "bash scripts/check-generic.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "docs": "typedoc --out docs-generated src/index.ts",
    "prepublishOnly": "npm run check:generic && npm run build && npm run typecheck && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@mozilla/readability": "^0.5.0",
    "@scarf/scarf": "^1.4.0",
    "fflate": "^0.8.3",
    "file-type": "^19.6.0",
    "jsdom": "^25.0.1",
    "mammoth": "^1.12.0",
    "unpdf": "^1.6.2",
    "uuid": "^13.0.0",
    "word-extractor": "^1.0.4",
    "ws": "^8.18.0",
    "yaml": "^2.8.3"
  },
  "scarfSettings": {
    "defaultOptIn": true
  },
  "peerDependencies": {
    "better-sqlite3": ">=11 <13"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "pg": "^8.11.0",
    "playwright": "^1.48.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^2.1.9",
    "better-sqlite3": "^12.8.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9.0.0",
    "pg": "^8.11.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typedoc": "^0.26.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "context",
    "sqlite",
    "memory",
    "sync"
  ],
  "license": "Apache-2.0",
  "homepage": "https://latticeSQL.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/automated-industries/lattice.git"
  },
  "bugs": {
    "url": "https://github.com/automated-industries/lattice/issues"
  }
}
